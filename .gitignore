# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/

# Data cache (only the top-level cache dir, not src/data/).
# Use /data/* (not /data/) so we can re-include specific files below.
/data/*
*.csv
*.parquet
*.pkl
!report/figures/*.csv
# Keep the Gemini sentiment cache + pre-warmed price parquet files in the
# repo so Streamlit Cloud cold starts have working data and don't depend on
# yfinance being reachable from AWS IPs (Yahoo frequently rate-limits them).
!/data/sentiment_cache.json
!/data/prices/
!/data/prices/*.parquet

# Streamlit
.streamlit/secrets.toml

